# ---- Database -------------------------------------------------------------
# Local docker-compose Postgres. Override for RDS/Aurora in production.
DATABASE_URL="postgresql://instainv:instainv@localhost:5432/instainv?schema=public"

# ---- Auth -----------------------------------------------------------------
# 32+ char random secret used to sign session JWTs. Generate with:
#   openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Session lifetime (seconds). Default 2 days.
SESSION_MAX_AGE="172800"

# Set "true" to force the Secure flag on session cookies even when NODE_ENV is not
# "production" (e.g. staging/preview behind HTTPS). Leave unset for local http dev.
# COOKIE_SECURE="true"

# ---- App ------------------------------------------------------------------
# Public base URL (used in emails, label QR codes, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="InstaInv"

# ---- Uploads / storage ----------------------------------------------------
# "local" stores files under public/uploads. Swap to "s3" in production.
STORAGE_DRIVER="local"
UPLOAD_DIR="public/uploads"
# S3 (only used when STORAGE_DRIVER=s3)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# ---- Email (approve/deny digest notifications) ----------------------------
# Resend HTTP API. Without these, decision emails are queued + logged but not sent.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="InstaInv <inventory@yourdomain.com>"
# Optional: secret for an external scheduler to hit GET /api/notifications/cron.
# NOTIFICATIONS_CRON_SECRET=""

# ---- OCR ------------------------------------------------------------------
# Language for Tesseract checklist OCR.
OCR_LANG="eng"

# ---- Seed -----------------------------------------------------------------
# Default admin created by `npm run seed`. If SEED_ADMIN_PASSWORD is left unset,
# the seed generates a strong random temporary password and prints it once; the
# account must change it on first login. Never ship a known default password.
SEED_ADMIN_EMAIL="admin@instainv.local"
# SEED_ADMIN_PASSWORD=""
